# =============================================
# 出海通 AsiaBridge — 环境变量配置
# 复制此文件为 .env.local 并填入实际值
# =============================================

# ─────────────────────────────────────────────
# 超级管理员账号（生产环境强烈建议替换）
# 默认：admin@asiabridge.com / AsiaBridge2026!
# ─────────────────────────────────────────────
ADMIN_EMAIL=admin@asiabridge.com
ADMIN_PASSWORD=AsiaBridge2026!
ADMIN_NAME=平台管理员

# 网站基础 URL（用于 sitemap.xml 生成，务必设置）
NEXT_PUBLIC_BASE_URL=https://asiabridge.example

# =============================================
# 数据采集定时任务（生产环境必须设置）
# =============================================

# API 路由鉴权密钥（用于 /api/cron/collect 路由保护）
# 推荐：openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# Vercel ISR 重新生成 Webhook（可选，仅 Vercel 部署时需要）
# 在 Vercel 项目 Dashboard → Settings → Git → Deploy Hooks 中创建
# 格式：https://api.vercel.com/v1/integrations/deploy/xxx
VERCEL_REVALIDATE_HOOK=

# =============================================
# Vercel 定时任务配置 (vercel.json)
# 每6小时自动触发数据采集
# =============================================
# vercel.json 中的 cron 配置：
# {
#   "crons": [{
#     "path": "/api/cron/collect",
#     "schedule": "0 */6 * * *"
#   }]
# }
